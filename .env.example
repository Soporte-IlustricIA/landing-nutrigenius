VITE_OPENCLAW_WS_URL=
VITE_OPENCLAW_API_KEY=
VITE_OPENCLAW_AGENT_ID=
VITE_OPENCLAW_SESSION_KEY=
# Opcional: id del chat/usuario para agent:telegram:telegram:direct:<id> si no usas SESSION_KEY completa
VITE_OPENCLAW_DIRECT_PEER_ID=
# Opcional: deliveryContext.to si el gateway no acepta la sessionKey como destino webchat
VITE_OPENCLAW_WEBCHAT_TO=
# Base pública para servir /out/* como enlace en el chat (ej. https://gateway.tu-dominio.com/files/out)
VITE_OPENCLAW_DOWNLOAD_BASE_URL=
